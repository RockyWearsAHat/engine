{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Engine Desktop",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:desktop"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "detail": "Starts the Engine desktop app for manual testing.",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Engine Workspace",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck Engine Workspace",
      "type": "shell",
      "command": "pnpm",
      "args": ["typecheck"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Check Engine Desktop",
      "type": "shell",
      "command": "pnpm",
      "args": ["check:desktop"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Smoke Test Engine",
      "type": "shell",
      "command": "pnpm",
      "args": ["smoke:system"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
