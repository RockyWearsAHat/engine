{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Engine Desktop",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:desktop"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "detail": "Starts the Engine desktop app for manual testing.",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Engine Workspace",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck Engine Workspace",
      "type": "shell",
      "command": "pnpm",
      "args": ["typecheck"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Check Engine Desktop",
      "type": "shell",
      "command": "pnpm",
      "args": ["check:desktop"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Smoke Test Engine",
      "type": "shell",
      "command": "pnpm",
      "args": ["smoke:system"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test Client (Vitest)",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@engine/client", "test:run"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test Client Coverage (Vitest)",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@engine/client", "test:coverage"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test Go Server",
      "type": "shell",
      "command": "go",
      "args": ["test", "./...", "-v", "-coverprofile=coverage.out", "-covermode=atomic"],
      "options": {
        "cwd": "${workspaceFolder}/packages/server-go"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test Rust (Cargo)",
      "type": "shell",
      "command": "node",
      "args": ["${workspaceFolder}/scripts/run-cargo.mjs", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Coverage All Languages (Unified Report)",
      "type": "shell",
      "command": "pnpm",
      "args": ["coverage:all"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test All Languages",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Test Client Coverage (Vitest)",
        "Test Go Server",
        "Test Rust (Cargo)"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
