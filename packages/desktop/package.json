{
  "name": "@myeditor/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k -n electron,wait \"sleep 2 && electron .\" \"tsc --watch --preserveWatchOutput\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dist": "tsc && electron-builder"
  },
  "dependencies": {
    "@myeditor/shared": "workspace:*",
    "electron": "^34.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "com.myeditor.app",
    "productName": "MyEditor",
    "directories": {
      "output": "../../release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": ["src/**", "package.json", "tsconfig.json"]
      },
      {
        "from": "../client/dist",
        "to": "client-dist"
      }
    ]
  }
}
