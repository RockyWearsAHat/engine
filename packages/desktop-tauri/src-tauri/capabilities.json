[
  {
    "identifier": "main-window",
    "description": "Capability for the main window with event permissions",
    "windows": ["main"],
    "permissions": [
      "core:event:allow-listen",
      "core:event:allow-emit",
      "core:window:allow-start-dragging",
      "opener:default",
      "opener:allow-open-url"
    ]
  }
]
